# D:/Accountiblity partner/.env.example

# Client-side Firebase Configuration Keys
FIREBASE_API_KEY="your-api-key"
FIREBASE_AUTH_DOMAIN="your-auth-domain.firebaseapp.com"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_STORAGE_BUCKET="your-storage-bucket.appspot.com"
FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
FIREBASE_APP_ID="your-app-id"

# Server-side / Admin-side Firebase Configuration Keys
# Stringified JSON credential file for service account
FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", "project_id": "...", ...}'

# Curfew Authentication Credentials (for Electron companion app)
CURFEW_USER_EMAIL="your-email@example.com"
CURFEW_USER_PASSWORD="your-password"
